{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["cdg1"],
  "crons": [
    {
      "path": "/api/cron/onboarding-emails",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/appel-loyers",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/quittances-auto",
      "schedule": "0 10 1 * *"
    },
    {
      "path": "/api/cron/rapport-hebdo",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/alertes-email",
      "schedule": "0 9 * * *"
    }
  ]
}
